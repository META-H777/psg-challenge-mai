{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "docs/**",
      "data/**",
      "deploy/**",
      "README.md"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
